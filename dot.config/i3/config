# set custom keybindings #
set $foo
    bindsym $mod+shift+p exec --no-startup-id scrot 'screenshot.png' -e 'xclip -selection c -t image/png $f'
    bindsym XF86AudioRaiseVolume exec --no-startup-id $psst pactl set-sink-volume @DEFAULT_SINK@ +1% && pactl set-sink-mute @DEFAULT_SINK@ 0 $update # volume up
    bindsym XF86AudioLowerVolume exec --no-startup-id $psst pactl set-sink-volume @DEFAULT_SINK@ -1% && pactl set-sink-mute @DEFAULT_SINK@ 0 $update # volume down
    bindsym XF86AudioMute exec --no-startup-id $psst pactl set-sink-mute @DEFAULT_SINK@ toggle $update # mute

    bindsym XF86MonBrightnessUp exec light -l -A 10 # increase screen brightness
    bindsym XF86MonBrightnessDown exec light -l -U 10 # decrease screen brightness
    bindsym XF86KbdBrightnessDown exec light -k -U 10 # decrease keyboard brightness
    bindsym XF86KbdBrightnessUp  exec light -k -A 10 # increase keyboard brightness

    #bindsym XF86AudioPlay exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.PlayPause"
    #bindsym XF86AudioStop exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Stop"
    #bindsym XF86AudioPrev exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Previous"
    #bindsym XF86AudioNext exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Next"
    bindsym XF86AudioPlay exec playerctl play
	bindsym XF86AudioPause exec playerctl pause
	bindsym XF86AudioNext exec playerctl next
	bindsym XF86AudioPrev exec playerctl previous


# RICE RICE BABY
set $foo
    gaps inner 15
    smart_borders no_gaps
    # exec --no-startup-id xautolock -time 10 -locker i3lock-wrapper
    bindsym $mod+l exec --no-startup-id i3lock-wrapper

    # use compositor
    exec --no-startup-id compton -b -c

    # hide title bars
    new_window 1pixel

# set wallpaper
exec --no-startup-id feh --bg-max "/home/max/.wallpaper.jpg"

# dmenu replacement (rofi)
