# vim: foldmethod=indent
# i3 config file (v4)
#
# Please see http://i3wm.org/docs/userguide.html for a complete reference!


# Bindings
   
    set $mod Mod4
    bindsym $mod+Shift+c reload
    bindsym $mod+Shift+r restart
    bindsym $mod+t exec terminator
    bindsym $mod+Shift+q kill 
    floating_modifier $mod 
    bindsym $mod+h split h 
    bindsym $mod+v split v 
    bindsym $mod+f fullscreen toggle 
    bindsym $mod+Shift+space floating toggle 
    bindsym $mod+space focus mode_toggle 
    bindsym $mod+a focus parent 
    
    # move focus:
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # move focused window
    bindsym $mod+Shift+j move left
    bindsym $mod+Shift+Left move left
    bindsym $mod+Shift+k move down
    bindsym $mod+Shift+Down move down
    bindsym $mod+Shift+l move up
    bindsym $mod+Shift+Up move up
    bindsym $mod+Shift+semicolon move right
    bindsym $mod+Shift+Right move right

    # change container layout (stacked, tabbed, toggle split)
    bindsym $mod+s layout stacking
    bindsym $mod+w layout tabbed
    bindsym $mod+e layout toggle split

    bindsym $mod+r mode "resize"
    bindsym $mod+Shift+e exit 

    # resize window (you can also use the mouse for that). These bindings trigger as soon as you enter the resize mode
    mode "resize" {
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape
        bindsym Return mode "default"
        bindsym Escape mode "default"
    }

# look and feel
    font pango:Source Code Pro Regular 14

# monitor and workspace layout
    set $mon_l DP-1
    set $mon_c DP-2
    set $mon_r HDMI-2

    workspace "1 vivaldi" output $mon_l
    workspace "2 chats" output $mon_c
    workspace 3 output $mon_l
    workspace "4 irc" output $mon_l
    workspace "5 email" output $mon_l
    workspace "6 spotify" output $mon_r
    workspace 7 output $mon_c
    workspace "8 intellij" output $mon_r
    workspace "9 gitkraken" output $mon_c
    workspace "10 pycharm" output $mon_r

    # switch to workspace
    bindsym $mod+1 workspace number 1 vivaldi
    assign [class="Vivaldi-stable"] number 1
    bindsym $mod+2 workspace number 2 chats
    assign [class="Slack"] number 2
    assign [class="Caprine"] number 2
    assign [class="discord"] number 2
    bindsym $mod+3 workspace number 3
    bindsym $mod+4 workspace number 4 irc
    assign [window_role="irssi"] number 4 irc
    bindsym $mod+5 workspace 5 email
    assign [window_role="neomutt"] number 5 email
    bindsym $mod+6 workspace 6 spotify
    for_window [class="Spotify"] move to workspace 6 spotify
    bindsym $mod+7 workspace 7
    bindsym $mod+8 workspace number 8 intellij
    bindsym $mod+9 workspace number 9 gitkraken
    assign [class="GitKraken"] number 9 gitkraken
    bindsym $mod+0 workspace number 10 pycharm
    assign [class="jetbrains-pycharm-ce"] number 10 pycharm

    # move focused container to workspace
    bindsym $mod+Shift+1 move container to workspace number 1 vivaldi
    bindsym $mod+Shift+2 move container to workspace number 2 chats
    bindsym $mod+Shift+3 move container to workspace number 3
    bindsym $mod+Shift+4 move container to workspace 4 irc
    bindsym $mod+Shift+5 move container to workspace 5 email
    bindsym $mod+Shift+6 move container to workspace 6 spotify
    bindsym $mod+Shift+7 move container to workspace 7
    bindsym $mod+Shift+8 move container to workspace number 8 intellij
    bindsym $mod+Shift+9 move container to workspace number 9 gitkraken
    bindsym $mod+Shift+0 move container to workspace number 10 pycharm

    exec --no-startup-id i3-msg 'workspace 1 vivaldi; vivaldi-stable;'
    exec --no-startup-id i3-msg 'workspace 2 chats; slack; caprine;'

    exec --no-startup-id i3-msg 'workspace 4 irc; irssi-terminator;'
    exec --no-startup-id i3-msg 'workspace 5 email; neomutt-terminator;'
    exec --no-startup-id i3-msg 'workspace 6 spotify; spotify;'
    
    exec --no-startup-id i3-msg 'workspace 9 gitkraken; gitkraken;' 
    exec --no-startup-id i3-msg 'workspace 10 pycharm; pycharm-community;'

# Status bars

    bar { 
        status_command    python3 ~/.config/i3/topi3pystatus.conf
        position          top
        workspace_buttons no
        font pango:Hack, Source Code Pro 10
        colors {
            background #222222
            statusline #eeeeee
            separator #666666
            #                  border  backgr. text
            focused_workspace  #4c7899 #285577 #ffffff
            active_workspace   #333333 #5f676a #ffffff
            inactive_workspace #333333 #222222 #888888
            urgent_workspace   #2f343a #900000 #ffffff
        }
    }

    bar { 
        status_command    python3 ~/.config/i3/bottomi3pystatus.conf
        position          bottom
        workspace_buttons yes
        font pango:Hack, Source Code Pro 10
        colors {
            background #222222
            statusline #eeeeee
            separator #666666
            #                  border  backgr. text
            focused_workspace  #4c7899 #285577 #ffffff
            active_workspace   #333333 #5f676a #ffffff
            inactive_workspace #333333 #222222 #888888
            urgent_workspace   #2f343a #900000 #ffffff
        }
    }

# start user configs #
exec setxkbmap -layout us -variant mac
exec xrandr -s 1920x1200
exec xinput set-prop 'bcm5974' "Synaptics Scrolling Distance" -247, -247

# set custom keybindings #
bindsym XF86AudioRaiseVolume exec --no-startup-id $psst pactl set-sink-volume @DEFAULT_SINK@ +5% && pactl set-sink-mute @DEFAULT_SINK@ 0 $update # volume up
bindsym XF86AudioLowerVolume exec --no-startup-id $psst pactl set-sink-volume @DEFAULT_SINK@ -5% && pactl set-sink-mute @DEFAULT_SINK@ 0 $update # volume down
bindsym XF86AudioMute exec --no-startup-id $psst pactl set-sink-mute @DEFAULT_SINK@ toggle $update # mute

bindsym XF86MonBrightnessUp exec light -l -A 10 # increase screen brightness
bindsym XF86MonBrightnessDown exec light -l -U 10 # decrease screen brightness
bindsym XF86KbdBrightnessDown exec light -k -U 10 # decrease keyboard brightness
bindsym XF86KbdBrightnessUp  exec light -k -A 10 # increase keyboard brightness

bindsym XF86AudioPlay exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.PlayPause"
bindsym XF86AudioStop exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Stop"
bindsym XF86AudioPrev exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Previous"
bindsym XF86AudioNext exec "dbus-send --print-reply --dest=org.mpris.MediaPlayer2.spotify /org/mpris/MediaPlayer2 org.mpris.MediaPlayer2.Player.Next"

bindsym $mod+shift+p exec --no-startup-id scrot 'screenshot.png' -e 'xclip -selection c -t image/png $f'

# RICE RICE BABY
gaps inner 15
smart_borders no_gaps
bindsym $mod+l exec --no-startup-id i3lock-wrapper
# exec --no-startup-id xautolock -time 10 -locker i3lock-wrapper

# use compositor
exec --no-startup-id compton -b -c

# hide title bars
new_window 1pixel

# set wallpaper
exec --no-startup-id feh --bg-fill "/home/max/.wallpaper.jpg"

# start dmenu (a program launcher)
# bindsym $mod+d exec dmenu_run -fn 'Source Code Pro Regular-14'
#
# dmenu replacement (rofi)
bindsym $mod+Return exec "rofi -show run -modi run -location 1 -width 100 -lines 2 -line-margin 0 -line-padding 1 -separator-style none -font 'mono 10' -columns 9 -bw 0 -disable-history -hide-scrollbar -color-window '#222222, #222222, #b1b4b3' -color-normal '#222222, #b1b4b3, #222222, #005577, #b1b4b3' -color-active '#222222, #b1b4b3, #222222, #007763, #b1b4b3' -color-urgent '#222222, #b1b4b3, #222222, #77003d, #b1b4b3' -kb-row-select 'Tab' -kb-row-tab ''"

exec --no-startup-id guake
exec --no-startup-id /usr/bin/gnome-keyring-daemon
exec slack
exec discord
exec messengerfordesktop
exec vivaldi-stable
exec pycharm-community
exec spotify --class Spotify
exec --no-startup-id /usr/bin/ckb-next -b

